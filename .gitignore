# Python bytecode
__pycache__/
*.pyc
*.pyo

# Virtualenv (local runtime, not versioned)
.venv/
venv/

# Pytest cache
.pytest_cache/

# SQLite databases (runtime state, not versioned)
data/*.db
data/*.db-shm
data/*.db-wal

# Stray tilde directory (from unexpanded tilde bug)
~/

# nohup output
nohup.out

# Browser e2e test output (bead adc-jr35): regenerable on every test run, not source.
# - screenshots/ : Playwright captures analyzed in-test by screenshot_analyze.py
# - .browser_libpath_cache.json : host-specific /nix/store lib-path cache
tests/e2e/screenshots/
tests/e2e/.browser_libpath_cache.json
